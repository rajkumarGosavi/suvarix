{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Suvarix",
  "identifier": "com.rajkumar.suvarix",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Suvarix",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFODNDQjcxRjE5Q0M5NUEKUldSYXlaenhjY3VEdnArZVNETUh6QmMvNEhad0JEbTZ6cUlzNldZcU5MTHp4WFd4MUI2eW81UmkK",
      "endpoints": [
        "https://github.com/rajkumarGosavi/suvarix/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
